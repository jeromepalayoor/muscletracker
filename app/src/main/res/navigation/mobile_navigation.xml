<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="net.jpalayoor.muscletracker.ui.home.HomeFragment"
        android:label="@string/title_home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/navigation_workouts"
        android:name="net.jpalayoor.muscletracker.ui.workouts.WorkoutsFragment"
        android:label="@string/title_workouts"
        tools:layout="@layout/fragment_workouts">

        <action
            android:id="@+id/action_template_to_detail"
            app:destination="@id/navigation_template_detail" />
    </fragment>

    <fragment
        android:id="@+id/navigation_record"
        android:name="net.jpalayoor.muscletracker.ui.record.RecordFragment"
        android:label="@string/title_record"
        tools:layout="@layout/fragment_record" />

    <fragment
        android:id="@+id/navigation_exercises"
        android:name="net.jpalayoor.muscletracker.ui.exercises.ExercisesFragment"
        android:label="@string/title_exercises"
        tools:layout="@layout/fragment_exercises">

        <action
            android:id="@+id/action_exercises_to_detail"
            app:destination="@id/navigation_exercise_detail" />
    </fragment>

    <fragment
        android:id="@+id/navigation_settings"
        android:name="net.jpalayoor.muscletracker.ui.settings.SettingsFragment"
        android:label="@string/title_settings"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/navigation_exercise_detail"
        android:name="net.jpalayoor.muscletracker.ui.exercises.ExerciseDetailFragment"
        android:label="Exercise Detail"
        tools:layout="@layout/fragment_exercise_detail" />

    <fragment
        android:id="@+id/navigation_template_detail"
        android:name="net.jpalayoor.muscletracker.ui.workouts.TemplateDetailFragment"
        android:label="Template Detail"
        tools:layout="@layout/fragment_template_detail" />
</navigation>